package controller

import (
	"context"
	"fmt"
	"time"

	"k8s.io/apimachinery/pkg/api/errors"
	"k8s.io/apimachinery/pkg/types"
	"sigs.k8s.io/controller-runtime/pkg/log"
	ctrl "sigs.k8s.io/controller-runtime"

	appsv1 "k8s.io/api/apps/v1"
	{{API_GROUP}}{{API_VERSION}} "{{REPO_PATH}}/api/{{API_VERSION}}"
)

func (r *{{KIND}}Reconciler) updateStatus(ctx context.Context, cr *{{API_GROUP}}{{API_VERSION}}.{{KIND}}) (ctrl.Result, error) {
	logger := log.FromContext(ctx)

	// Fetch the primary dependent resource
	sts := &appsv1.StatefulSet{}
	err := r.Get(ctx, types.NamespacedName{Name: cr.Name, Namespace: cr.Namespace}, sts)
	if err != nil {
		if errors.IsNotFound(err) {
			return ctrl.Result{RequeueAfter: 10 * time.Second}, nil
		}
		return ctrl.Result{}, err
	}

	// Copy status fields from dependent resource
	cr.Status.ReadyReplicas = sts.Status.ReadyReplicas
	cr.Status.Endpoint = fmt.Sprintf("%s-service.%s.svc.cluster.local", cr.Name, cr.Namespace)

	// Determine phase
	if sts.Status.ReadyReplicas == cr.Spec.Replicas {
		cr.Status.Phase = "Running"
	} else {
		cr.Status.Phase = "Initializing"
	}

	// Update status subresource
	if err := r.Status().Update(ctx, cr); err != nil {
		logger.Error(err, "Failed to update status")
		return ctrl.Result{}, err
	}

	// Update conditions based on phase
	if err := r.updateConditionsForPhase(ctx, cr); err != nil {
		return ctrl.Result{}, err
	}

	// Requeue if not all replicas ready
	if cr.Status.ReadyReplicas < cr.Spec.Replicas {
		return ctrl.Result{RequeueAfter: 10 * time.Second}, nil
	}

	return ctrl.Result{}, nil
}

func (r *{{KIND}}Reconciler) updatePhase(ctx context.Context, cr *{{API_GROUP}}{{API_VERSION}}.{{KIND}}, phase string) (ctrl.Result, error) {
	cr.Status.Phase = phase
	if err := r.Status().Update(ctx, cr); err != nil {
		return ctrl.Result{}, err
	}
	return ctrl.Result{Requeue: true}, nil
}
