	"sigs.k8s.io/controller-runtime/pkg/log"

	{{API_GROUP}}{{API_VERSION}} "{{REPO_PATH}}/api/{{API_VERSION}}"
)

const finalizerName = "{{FULL_GROUP}}/finalizer"

type {{KIND}}Reconciler struct {
	client.Client
	Scheme   *runtime.Scheme
	Recorder record.EventRecorder
}

//+kubebuilder:rbac:groups={{FULL_GROUP}},resources={{KIND_PLURAL}},verbs=get;list;watch;create;update;patch;delete
//+kubebuilder:rbac:groups={{FULL_GROUP}},resources={{KIND_PLURAL}}/status,verbs=get;update;patch
//+kubebuilder:rbac:groups={{FULL_GROUP}},resources={{KIND_PLURAL}}/finalizers,verbs=update
//+kubebuilder:rbac:groups="",resources=events,verbs=create;patch
// TODO: Add RBAC markers for each managed resource type

func (r *{{KIND}}Reconciler) Reconcile(ctx context.Context, req ctrl.Request) (ctrl.Result, error) {
	logger := log.FromContext(ctx)

	// PHASE 1: FETCH
	cr := &{{API_GROUP}}{{API_VERSION}}.{{KIND}}{}
	if err := r.Get(ctx, req.NamespacedName, cr); err != nil {
		if errors.IsNotFound(err) {
			logger.Info("{{KIND}} not found, likely deleted")
			return ctrl.Result{}, nil
		}
		return ctrl.Result{}, err
	}

	if !cr.DeletionTimestamp.IsZero() {
		return r.handleDeletion(ctx, cr)
	}

	// PHASE 2: ORCHESTRATE
	if !controllerutil.ContainsFinalizer(cr, finalizerName) {
		controllerutil.AddFinalizer(cr, finalizerName)
		if err := r.Update(ctx, cr); err != nil {
			return ctrl.Result{}, err
		}
	}

	// TODO: Call reconcileX methods in dependency order
	// if err := r.reconcileSecret(ctx, cr); err != nil {
	//     return r.handleError(ctx, cr, err, "Secret failed")
	// }

	// PHASE 3: STATUS
	return r.updateStatus(ctx, cr)
}

func (r *{{KIND}}Reconciler) handleDeletion(ctx context.Context, cr *{{API_GROUP}}{{API_VERSION}}.{{KIND}}) (ctrl.Result, error) {
	if !controllerutil.ContainsFinalizer(cr, finalizerName) {
		return ctrl.Result{}, nil
	}

	r.Recorder.Event(cr, "Normal", "Deleting", "Starting cleanup")

	// TODO: Perform cleanup here

	controllerutil.RemoveFinalizer(cr, finalizerName)
	if err := r.Update(ctx, cr); err != nil {
		return ctrl.Result{}, err
	}

	r.Recorder.Event(cr, "Normal", "Deleted", "Cleanup completed")
	return ctrl.Result{}, nil
}

func (r *{{KIND}}Reconciler) handleError(ctx context.Context, cr *{{API_GROUP}}{{API_VERSION}}.{{KIND}}, err error, msg string) (ctrl.Result, error) {
	log.FromContext(ctx).Error(err, msg)
	r.Recorder.Event(cr, "Warning", "ReconcileError", fmt.Sprintf("%s: %v", msg, err))
	cr.Status.Phase = "Failed"
	_ = r.Status().Update(ctx, cr)
	return ctrl.Result{RequeueAfter: 30 * time.Second}, err
}

func (r *{{KIND}}Reconciler) SetupWithManager(mgr ctrl.Manager) error {
	return ctrl.NewControllerManagedBy(mgr).
		For(&{{API_GROUP}}{{API_VERSION}}.{{KIND}}{}).
		// TODO: Add Owns() for each managed resource type
		Complete(r)
}
