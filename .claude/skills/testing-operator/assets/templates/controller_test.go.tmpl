package controller

import (
	"context"
	"fmt"
	"time"

	. "github.com/onsi/ginkgo/v2"
	. "github.com/onsi/gomega"

	metav1 "k8s.io/apimachinery/pkg/apis/meta/v1"
	"k8s.io/apimachinery/pkg/types"
	"k8s.io/client-go/tools/record"
	"sigs.k8s.io/controller-runtime/pkg/reconcile"

	{{API_GROUP}}{{API_VERSION}} "{{REPO_PATH}}/api/{{API_VERSION}}"
)

var _ = Describe("{{KIND}} Controller", func() {
	const (
		timeout  = time.Second * 10
		interval = time.Millisecond * 250
	)

	Context("When reconciling a {{KIND}}", func() {
		var (
			ctx        context.Context
			name       string
			namespace  string
			key        types.NamespacedName
			cr         *{{API_GROUP}}{{API_VERSION}}.{{KIND}}
			reconciler *{{KIND}}Reconciler
		)

		BeforeEach(func() {
			ctx = context.Background()
			name = fmt.Sprintf("test-%d", time.Now().UnixNano())
			namespace = "default"
			key = types.NamespacedName{Name: name, Namespace: namespace}

			cr = &{{API_GROUP}}{{API_VERSION}}.{{KIND}}{
				ObjectMeta: metav1.ObjectMeta{
					Name:      name,
					Namespace: namespace,
				},
				Spec: {{API_GROUP}}{{API_VERSION}}.{{KIND}}Spec{
					// TODO: Fill in test spec fields
				},
			}

			reconciler = &{{KIND}}Reconciler{
				Client:   k8sClient,
				Scheme:   k8sClient.Scheme(),
				Recorder: record.NewFakeRecorder(100),
			}

			Expect(k8sClient.Create(ctx, cr)).To(Succeed())
		})

		AfterEach(func() {
			resource := &{{API_GROUP}}{{API_VERSION}}.{{KIND}}{}
			if err := k8sClient.Get(ctx, key, resource); err == nil {
				// Remove finalizer to allow cleanup
				resource.Finalizers = nil
				_ = k8sClient.Update(ctx, resource)
				Expect(k8sClient.Delete(ctx, resource)).To(Succeed())
			}
		})

		It("should add finalizer on first reconciliation", func() {
			_, err := reconciler.Reconcile(ctx, reconcile.Request{NamespacedName: key})
			Expect(err).NotTo(HaveOccurred())

			updated := &{{API_GROUP}}{{API_VERSION}}.{{KIND}}{}
			Expect(k8sClient.Get(ctx, key, updated)).To(Succeed())
			Expect(updated.Finalizers).NotTo(BeEmpty())
		})

		It("should create all managed resources", func() {
			// May need multiple reconciliations
			for i := 0; i < 3; i++ {
				_, _ = reconciler.Reconcile(ctx, reconcile.Request{NamespacedName: key})
			}

			// TODO: Verify each managed resource exists
			// Expect(k8sClient.Get(ctx, secretKey, &corev1.Secret{})).To(Succeed())
		})

		It("should be idempotent on repeated reconciliation", func() {
			_, _ = reconciler.Reconcile(ctx, reconcile.Request{NamespacedName: key})
			result, err := reconciler.Reconcile(ctx, reconcile.Request{NamespacedName: key})
			Expect(err).NotTo(HaveOccurred())
			_ = result // second reconcile should not fail
		})
	})
})
