package e2e

import (
	"fmt"
	"os/exec"
	"time"
	"testing"

	. "github.com/onsi/ginkgo/v2"
	. "github.com/onsi/gomega"
)

const namespace = "{{OPERATOR_NAME}}-system"

func TestE2E(t *testing.T) {
	RegisterFailHandler(Fail)
	RunSpecs(t, "E2E Suite")
}

var _ = Describe("{{OPERATOR_NAME}}", Ordered, func() {
	BeforeAll(func() {
		By("creating manager namespace")
		cmd := exec.Command("kubectl", "create", "ns", namespace)
		_, _ = cmd.CombinedOutput()
	})

	AfterAll(func() {
		By("removing manager namespace")
		cmd := exec.Command("kubectl", "delete", "ns", namespace)
		_, _ = cmd.CombinedOutput()
	})

	It("should deploy and run successfully", func() {
		projectImage := "{{IMAGE_TAG_BASE}}:test"

		By("building the operator image")
		cmd := exec.Command("make", "docker-build", fmt.Sprintf("IMG=%s", projectImage))
		out, err := cmd.CombinedOutput()
		Expect(err).NotTo(HaveOccurred(), string(out))

		By("deploying the controller")
		cmd = exec.Command("make", "deploy", fmt.Sprintf("IMG=%s", projectImage))
		out, err = cmd.CombinedOutput()
		Expect(err).NotTo(HaveOccurred(), string(out))

		By("verifying controller pod is running")
		Eventually(func() error {
			cmd := exec.Command("kubectl", "get", "pods", "-n", namespace,
				"-l", "control-plane=controller-manager",
				"-o", "jsonpath={.items[0].status.phase}")
			out, err := cmd.CombinedOutput()
			if err != nil { return err }
			if string(out) != "Running" {
				return fmt.Errorf("pod not running: %s", out)
			}
			return nil
		}, time.Minute, time.Second).Should(Succeed())
	})
})
